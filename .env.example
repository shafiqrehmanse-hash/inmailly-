# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (production)
NEXT_PUBLIC_APP_URL=https://inmailly.com

# Resend (https://resend.com) — required for signup/verification emails
# 1. Add and verify your domain at resend.com/domains
# 2. Set EMAIL_FROM to an address on that domain
# 3. Set NOTIFY_EMAIL to your inbox (admin alerts on signup + verify)
RESEND_API_KEY=
EMAIL_FROM=InMailly <notifications@inmailly.com>
NOTIFY_EMAIL=hello@inmailly.com
