</section>

<footer>
  <div class="ft">
    <div class="ft-logo">InMailly</div>
    <ul class="ft-links">
      <li><a href="#">Pricing</a></li>
      <li><a href="#">Features</a></li>
      <li><a href="#">Login</a></li>
      <li><a href="#">Privacy</a></li>
    </ul>
    <div class="ft-copy">© 2026 InMailly. LinkedIn outreach at scale.</div>
  </div>
</footer>

<script>
// Counter animation
function animateCount(el, target, duration, fmt) {
  let start = null;
  const step = ts => {
    if (!start) start = ts;
    const p = Math.min((ts - start) / duration, 1);
    const ease = 1 - Math.pow(1 - p, 3);
    const val = target * ease;
    el.textContent = fmt(val);
    if (p < 1) requestAnimationFrame(step);
  };
  requestAnimationFrame(step);
}

const io = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    animateCount(document.getElementById('c1'), 2847, 2000, v => Math.round(v).toLocaleString());
    animateCount(document.getElementById('c2'), 11.4, 1800, v => v.toFixed(1) + '%');
    animateCount(document.getElementById('c3'), 0.275, 1600, v => '$' + v.toFixed(3));
    io.disconnect();
    // keep ticking after load
    setInterval(() => {
      const el = document.getElementById('c1');
      if (!el) return;
      const cur = parseInt(el.textContent.replace(/,/g,''));
      if (!isNaN(cur)) el.textContent = (cur + Math.floor(Math.random() * 3 + 1)).toLocaleString();
    }, 3800);
  });
}, { threshold: 0.3 });
io.observe(document.querySelector('.counter-strip'));

// Scroll reveal
const cards = document.querySelectorAll('.fc,.pc,.tc,.step');
const revIo = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    const idx = [...cards].indexOf(e.target) % 4;
    setTimeout(() => {
      e.target.style.opacity = '1';
      e.target.style.transform = 'translateY(0)';
    }, idx * 70);
    revIo.unobserve(e.target);
  });
}, { threshold: 0.1 });
cards.forEach(c => {
  c.style.opacity = '0';
  c.style.transform = 'translateY(16px)';
  c.style.transition = 'opacity .45s ease, transform .45s ease';
  revIo.observe(c);
});
</script>
</body>
</html>
